# ================================
# CACHE & TEMPORÄRE DATEIEN
# ================================

# PHP Cache
/cache/
/tmp/
*.cache
*.tmp

# Session Dateien
/sessions/
*.sess

# Logs
/logs/
*.log

# Playwright auth state
/playwright/.auth/
/test-results/
/playwright-report/


# ================================
# IDE & EDITOR
# ================================

node_modules/*

.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.DS_Store

# ================================
# COMPOSER
# ================================

vendor/
composer.lock

# ================================
# UMGEBUNGSVARIABLEN
# ================================

.env
.env.local
.env.*.local

# ================================
# DATENBANK
# ================================

*.sql
*.sqlite
*.sqlite3

# Migrationen sind kein DB-Dump, sondern Quellcode
!app/lib/migrations/*.sql

# ================================
# NODE (falls später verwendet)
# ================================

node_modules/
npm-debug.log
yarn-error.log

# ================================
# OS DATEIEN
# ================================

Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# ================================
# SICHERHEIT
# ================================

*.key
*.pem
.env.production.local
